pipeline {
    agent any
    
    environment {
        DOCKER_HUB_USERNAME = 'wacimabdelli'
        BACKEND_IMAGE = "${DOCKER_HUB_USERNAME}/task-manager-backend"
        FRONTEND_IMAGE = "${DOCKER_HUB_USERNAME}/task-manager-frontend"
        MINIKUBE_PATH = 'C:\\Users\\pc\\Desktop\\devops\\Atelier-7-Kubernetes\\minikube.exe'
    }
    
    stages {
        stage('Checkout') {
            steps {
                echo '📥 Checking out code from GitHub...'
                git branch: 'main', url: 'https://github.com/wacim-abdellli/devops-workshop.git'
            }
        }
        
        stage('Build Images') {
            steps {
                echo '🐳 Building Docker images...'
                dir('Atelier-8-CI-CD-Pipeline') {
                    bat 'docker build -t %BACKEND_IMAGE%:latest app/backend'
                    bat 'docker build -t %FRONTEND_IMAGE%:latest app/frontend'
                }
            }
        }
        
        stage('Push to Docker Hub') {
            steps {
                echo '📤 Pushing to Docker Hub...'
                withCredentials([usernamePassword(credentialsId: 'dockerhub-credentials', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                    bat '''
                        docker login -u %DOCKER_USER% -p %DOCKER_PASS%
                        docker push %BACKEND_IMAGE%:latest
                        docker push %FRONTEND_IMAGE%:latest
                        docker logout
                    '''
                }
            }
        }
        
        stage('Deploy to Kubernetes') {
            steps {
                echo '☸️ Deploying to Kubernetes...'
                bat '''
                    %MINIKUBE_PATH% kubectl -- apply -f Atelier-8-CI-CD-Pipeline/kubernetes/namespace.yaml
                    %MINIKUBE_PATH% kubectl -- apply -f Atelier-8-CI-CD-Pipeline/kubernetes/backend-deployment.yaml
                    %MINIKUBE_PATH% kubectl -- apply -f Atelier-8-CI-CD-Pipeline/kubernetes/backend-service.yaml
                    %MINIKUBE_PATH% kubectl -- apply -f Atelier-8-CI-CD-Pipeline/kubernetes/frontend-configmap.yaml
                    %MINIKUBE_PATH% kubectl -- apply -f Atelier-8-CI-CD-Pipeline/kubernetes/frontend-deployment-local.yaml
                    %MINIKUBE_PATH% kubectl -- apply -f Atelier-8-CI-CD-Pipeline/kubernetes/frontend-service.yaml
                    %MINIKUBE_PATH% kubectl -- rollout restart deployment/backend -n task-manager
                    %MINIKUBE_PATH% kubectl -- rollout restart deployment/frontend -n task-manager
                '''
            }
        }
        
        stage('Verify Deployment') {
            steps {
                echo '✅ Verifying deployment...'
                bat '''
                    %MINIKUBE_PATH% kubectl -- get pods -n task-manager
                    %MINIKUBE_PATH% kubectl -- get services -n task-manager
                '''
            }
        }
    }
    
    post {
        success {
            echo '✅ ========================================='
            echo '✅ PIPELINE SUCCESS!'
            echo '✅ Application deployed to Kubernetes!'
            echo '✅ Images pushed to Docker Hub!'
            echo '✅ ========================================='
        }
        failure {
            echo '❌ Pipeline FAILED!'
        }
    }
}
